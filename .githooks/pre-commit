#!/bin/sh
# Pre-commit hook: keeps docs/version.json in sync with the highest
# VersionUpdate class version. Runs automatically before every commit.
#
# To activate after cloning:
#   git config core.hooksPath .githooks

VERSIONS_DIR="src/Classes/VersionHandler/Versions"
DOCS_VERSION_FILE="docs/version.json"

# Nothing to do if the Versions directory doesn't exist yet
if [ ! -d "$VERSIONS_DIR" ]; then
    exit 0
fi

# Find the highest version by natural numeric sort on each segment.
# Works without PHP — pure POSIX sh + sort.
LATEST=$(find "$VERSIONS_DIR" -maxdepth 1 -name 'Version_*.php' 2>/dev/null \
    | while IFS= read -r f; do basename "$f" .php; done \
    | sed 's/^Version_//' \
    | tr '_' '.' \
    | sort -t. -k1,1n -k2,2n -k3,3n \
    | tail -1)

# Nothing to do if no version files exist
if [ -z "$LATEST" ]; then
    exit 0
fi

# Read the currently stored version without PHP (plain text grep)
CURRENT=$(grep -o '"version"[[:space:]]*:[[:space:]]*"[^"]*"' "$DOCS_VERSION_FILE" 2>/dev/null \
    | grep -o '"[^"]*"$' \
    | tr -d '"')

# Only rewrite and stage if the version has actually changed
if [ "$CURRENT" != "$LATEST" ]; then
    UPDATED=$(date -u +"%Y-%m-%d %H:%M:%S")
    printf '{\n    "version": "%s",\n    "updated": "%s"\n}\n' "$LATEST" "$UPDATED" > "$DOCS_VERSION_FILE"
    git add "$DOCS_VERSION_FILE"
    echo "docs/version.json updated to $LATEST"
fi

exit 0
